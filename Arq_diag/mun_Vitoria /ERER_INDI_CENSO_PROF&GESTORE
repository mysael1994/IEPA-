# funcao de carregamento das livrarias (caso nao esteja instalado, sera feita a instalacao auto)
instalar_e_carregar <- function(pacotes) {
  for (pacote in pacotes) {
    if (!require(pacote, character.only = TRUE)) {
      install.packages(pacote, dependencies = TRUE)
      library(pacote, character.only = TRUE)
    }
  }
}

# Lista de livrarias que serao utilizados 
pacotes_necessarios <- c("dplyr","tidyr","ggplot2","lubridate","basedosdados","openxlsx")

#carregando pacotes 
instalar_e_carregar(pacotes_necessarios)


