# Abrindo base 5 ano EF e Selecionando apenas VI´toria e rede municipal #
Saeb_5EF <- basedosdados::read_sql('SELECT sigla_uf,id_regiao,id_municipio,id_aluno,rede,serie,proficiencia, disciplina,peso_aluno,
                                     proficiencia_saeb,sexo,raca_cor,nivel_inse,inse FROM `basedosdados.br_inep_saeb.aluno_ef_5ano` WHERE ano =2023')

# Abrindo base 9 ano EF e Selecionando apenas Vitoria e rede municipal #
