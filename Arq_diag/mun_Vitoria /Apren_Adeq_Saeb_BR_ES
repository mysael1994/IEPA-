)

# Codificando aprendizagem adequada (classificação Qedu) - https://conteudos.qedu.org.br/academia/aprendizado-adequado/

Saeb_5EF <- Saeb_5EF %>% mutate(LP_adequado = ifelse(proficiencia_saeb >= 200 & disciplina =="LP" ,1,0))
Saeb_5EF <- Saeb_5EF %>% mutate(MAT_adequado = ifelse(proficiencia_saeb >= 225 & disciplina =="MT",1,0))
Saeb_9EF <- Saeb_9EF %>% mutate(LP_adequado = ifelse(proficiencia_saeb >= 275 & disciplina =="LP" ,1,0))
Saeb_9EF <- Saeb_9EF %>% mutate(MAT_adequado = ifelse(proficiencia_saeb >= 300 & disciplina =="MT",1,0))

# Comparando proficiência negros e brancos para BR, CE e Sobral

## BR ##
Saeb_Adequado_LP_5EF_BR <- subset(Saeb_5EF, disciplina == "LP") %>% group_by(raca) %>% summarise(LP_adequado = weighted.mean(LP_adequado,peso_aluno))
Saeb_Adequado_MAT_5EF_BR <- subset(Saeb_5EF, disciplina == "MT") %>% group_by(raca) %>% summarise(MAT_adequado = weighted.mean(MAT_adequado,peso_aluno))
Saeb_Adequado_LP_9EF_BR <- subset(Saeb_9EF, disciplina == "LP") %>% group_by(raca) %>% summarise(LP_adequado = weighted.mean(LP_adequado,peso_aluno))
