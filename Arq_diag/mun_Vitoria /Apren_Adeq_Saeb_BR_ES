                  ifelse(raca_cor == "B", "Preto",
                         ifelse(raca_cor == "C", "Pardo",
                                ifelse(raca_cor == "D", "Amarela",
                                       ifelse(raca_cor == "E", "Indígena", "ND")))))
  )



# Codificando cor/raca 9EF
#Saeb_9EF <- Saeb_9EF %>% mutate(raca = ifelse (raca_cor == "A","branco",
