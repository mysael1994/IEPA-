# funcao de carregamento das livrarias (caso nao esteja instalado, sera feita a instalacao auto)
instalar_e_carregar <- function(pacotes) {
  for (pacote in pacotes) {
    if (!require(pacote, character.only = TRUE)) {
      install.packages(pacote, dependencies = TRUE)
      library(pacote, character.only = TRUE)
    }
  }
}

# Lista de livrarias que serao utilizados 
pacotes_necessarios <- c("dplyr","tidyr","ggplot2","lubridate","basedosdados")

#carregando pacotes 
instalar_e_carregar(pacotes_necessarios)

set_billing_id("mahin-dados")

Infraescola_2023 <- basedosdados::read_sql('SELECT sigla_uf,ano,id_municipio,id_escola,rede,profissional_psicologo,biblioteca,laboratorio_informatica,acesso_internet_computador,
                                      etapa_ensino_infantil, etapa_ensino_fundamental, quantidade_matricula_nao_declarada,quantidade_matricula_branca,
quantidade_matricula_preta,quantidade_matricula_parda,quantidade_matricula_amarela,quantidade_matricula_indigena FROM `basedosdados.br_inep_censo_escolar.escola` WHERE ano =2023')

# Função para mudar classe de integer64 para integer #

is.integer64 <- function(x){
  class(x)=="integer64"
}

Infraescola_2023 <- Infraescola_2023 %>% mutate_if(is.integer64, as.integer)
#trazeno ja os dados do IDEB
#query <- bdplyr("br_bd_diretorios_brasil.municipio")
set_billing_id("ideb-412717")


ideb_2023 <- basedosdados::read_sql('SELECT * 
                                    FROM `basedosdados.br_inep_ideb.escola` WHERE ano = 2023')

#ajustando a infra
Infraescola_2023 <- Infraescola_2023 %>%
  mutate(
    total_declarado =
      quantidade_matricula_branca +
      quantidade_matricula_preta +
      quantidade_matricula_parda +
      quantidade_matricula_amarela +
      quantidade_matricula_indigena,
    
    total_geral =
      total_declarado +
      quantidade_matricula_nao_declarada,
    
    prop_negro =
      (quantidade_matricula_preta +
         quantidade_matricula_parda) / total_declarado,
    
    prop_branco =
      quantidade_matricula_branca / total_declarado,
    
    prop_nao_declarada =
      quantidade_matricula_nao_declarada / total_geral
  ) %>%
  filter(
    rede == "3",
    id_municipio == "3205309",
    etapa_ensino_fundamental == 1,
    total_declarado > 0
  )

summary(Infraescola_2023$prop_nao_declarada)

#pegando Inde de vitoria
ideb_vitoria_2023 <- ideb_2023 %>%
  mutate(
    ano = as.integer(ano)
  ) %>%
  filter(
    ano == 2023,
    id_municipio == "3205309",
    rede == "municipal",
    ensino == "fundamental",
    anos_escolares %in% c(
      "iniciais (1-5)",
      "finais (6-9)"
    ),
    !is.na(ideb)
  ) %>%
  select(
    id_escola,
    anos_escolares,
    taxa_aprovacao,
    indicador_rendimento,
    nota_saeb_matematica,
    nota_saeb_lingua_portuguesa,
    nota_saeb_media_padronizada,
    ideb
  )

ideb_vitoria_2023 %>%
  count(id_escola, anos_escolares) %>%
  filter(n > 1)

ideb_vitoria_2023 %>%
  count(anos_escolares)

#juntando
completa_2023 <- Infraescola_2023 %>%
  inner_join(
    ideb_vitoria_2023,
    by = "id_escola"
  )

#verificando
nrow(completa_2023)

n_distinct(completa_2023$id_escola)

completa_2023 %>%
  count(anos_escolares)

completa_2023 %>%
  count(id_escola, anos_escolares) %>%
  filter(n > 1)

#criando duas bases
ideb_iniciais <- completa_2023 %>%
  filter(anos_escolares == "iniciais (1-5)")

ideb_finais <- completa_2023 %>%
  filter(anos_escolares == "finais (6-9)")

nrow(ideb_iniciais)
nrow(ideb_finais)

#iniciando a etapa descritiva
ideb_iniciais %>%
  summarise(
    escolas = n_distinct(id_escola),
    prop_negro_media = mean(prop_negro, na.rm = TRUE),
    prop_negro_mediana = median(prop_negro, na.rm = TRUE),
    ideb_medio = mean(ideb, na.rm = TRUE),
    ideb_mediano = median(ideb, na.rm = TRUE),
    ideb_minimo = min(ideb, na.rm = TRUE),
    ideb_maximo = max(ideb, na.rm = TRUE)
  )

ideb_finais %>%
  summarise(
    escolas = n_distinct(id_escola),
    prop_negro_media = mean(prop_negro, na.rm = TRUE),
    prop_negro_mediana = median(prop_negro, na.rm = TRUE),
    ideb_medio = mean(ideb, na.rm = TRUE),
    ideb_mediano = median(ideb, na.rm = TRUE),
    ideb_minimo = min(ideb, na.rm = TRUE),
    ideb_maximo = max(ideb, na.rm = TRUE)
  )

#dispersão
library(ggplot2)
library(scales)

