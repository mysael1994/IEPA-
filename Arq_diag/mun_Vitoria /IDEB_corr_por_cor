  geom_smooth(
    method = "lm",
    se = TRUE
  ) +
  scale_x_continuous(
    labels = percent_format(accuracy = 1)
  ) +
  labs(
    title = "IDEB e proporção de estudantes negros",
    subtitle = "Anos iniciais do ensino fundamental — Vitória, 2023",
    x = "Proporção de estudantes pretos e pardos",
    y = "IDEB"
  ) +
  theme_minimal()

