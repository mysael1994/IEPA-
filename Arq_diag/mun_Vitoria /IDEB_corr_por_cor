#Calculo das correlações 
#anos iniciais
cor.test(
  ideb_iniciais$prop_negro,
  ideb_iniciais$ideb,
  method = "pearson"
)

cor.test(
  ideb_iniciais$prop_negro,
  ideb_iniciais$ideb,
  method = "spearman",
  exact = FALSE
)

#anos finais 
cor.test(
  ideb_finais$prop_negro,
  ideb_finais$ideb,
  method = "pearson"
)

cor.test(
  ideb_finais$prop_negro,
  ideb_finais$ideb,
  method = "spearman",
  exact = FALSE
)

#comparar os resultados com as escolas mais negras e brancas
ideb_iniciais <- ideb_iniciais %>%
  mutate(
    grupo_racial = if_else(
      prop_negro >= median(prop_negro, na.rm = TRUE),
      "Maior proporção de estudantes negros",
      "Menor proporção de estudantes negros"
    )
  )

ideb_iniciais %>%
  group_by(grupo_racial) %>%
  summarise(
    escolas = n_distinct(id_escola),
    proporcao_negra_media = mean(prop_negro, na.rm = TRUE),
    ideb_medio = mean(ideb, na.rm = TRUE),
    ideb_mediano = median(ideb, na.rm = TRUE),
    desvio_padrao = sd(ideb, na.rm = TRUE)
  )

wilcox.test(
  ideb ~ grupo_racial,
  data = ideb_iniciais,
  exact = FALSE
)

#anos finais 
ideb_finais <- ideb_finais %>%
  mutate(
    grupo_racial = if_else(
      prop_negro >= median(prop_negro, na.rm = TRUE),
      "Maior proporção de estudantes negros",
      "Menor proporção de estudantes negros"
    )
  )

ideb_finais %>%
  group_by(grupo_racial) %>%
  summarise(
    escolas = n_distinct(id_escola),
    proporcao_negra_media = mean(prop_negro, na.rm = TRUE),
    ideb_medio = mean(ideb, na.rm = TRUE),
    ideb_mediano = median(ideb, na.rm = TRUE),
    desvio_padrao = sd(ideb, na.rm = TRUE)
  )

wilcox.test(
  ideb ~ grupo_racial,
  data = ideb_finais,
  exact = FALSE
)

#regressão linear simples
modelo_iniciais <- lm(
  ideb ~ prop_negro,
  data = ideb_iniciais
)

summary(modelo_iniciais)

modelo_finais <- lm(
  ideb ~ prop_negro,
  data = ideb_finais
)

summary(modelo_finais)

