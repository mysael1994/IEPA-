matricula.2025 <- matricula.2025 %>%
  mutate(
    grupo_racial =
      ifelse(prop_negro >= median(prop_negro),
             "Maior proporção de estudantes negros",
             "Menor proporção de estudantes negros")
  )

matricula.2025 %>%
  group_by(grupo_racial) %>%
  summarise(
    
    escolas=n(),
    
    indice_geral=mean(indice_geral),
    
    pedagogico=mean(indice_pedagogico),
    
    tecnologia=mean(indice_tecnologia),
    
    convivência=mean(indice_convivencia),
    
    acessibilidade=mean(indice_acessibilidade),
    
    equidade=mean(indice_equidade)
  )

wilcox.test(indice_geral ~ grupo_racial,
            data=matricula.2025)


