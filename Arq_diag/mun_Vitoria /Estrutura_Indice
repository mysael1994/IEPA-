# juntando as bases
matricula.2025 <- merge(matricula.2025, Escolas.2025, by = "CO_ENTIDADE")


#filtro só Municipal e Vitoria
matricula.2025 <- subset(matricula.2025, TP_DEPENDENCIA==3 & CO_MUNICIPIO ==3205309)
#matricula.2025 <- subset(matricula.2025, TP_DEPENDENCIA ==3 & SG_UF  =="ES")


#ETAPAS
#matricula.2025 <- subset(matricula.2025, IN_COMUM_FUND_AI==1) #anos inicias
#matricula.2025 <- subset(matricula.2025, IN_COMUM_FUND_AF==1) #anos finais
matricula.2025 <- subset(matricula.2025, IN_COMUM_CRECHE ==1 | IN_COMUM_PRE==1) #educação basica



#ajustando pra pegar a maioria negra ou branca
#criando coluna total de matriculas por cor
matricula.2025 <- matricula.2025 %>% mutate(total = QT_MAT_BAS_ND+QT_MAT_BAS_BRANCA+
                                              QT_MAT_BAS_PRETA+QT_MAT_BAS_PARDA+QT_MAT_BAS_AMARELA+QT_MAT_BAS_INDIGENA)


#adicionando as proporções por escolas
matricula.2025 <- matricula.2025 %>%  mutate(prop_branco = QT_MAT_BAS_BRANCA/total,
                                             prop_amarela = QT_MAT_BAS_AMARELA/total,
                                             prop_indigena = QT_MAT_BAS_INDIGENA/total,
                                             prop_negro = (QT_MAT_BAS_PRETA + QT_MAT_BAS_PARDA)/total)

