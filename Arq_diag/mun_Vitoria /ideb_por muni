#pegando dados do censo escolar 

set_billing_id("mahin-dados")




Escola_2022 <- basedosdados::read_sql('SELECT sigla_uf,ano,id_municipio,id_escola,rede, quantidade_matricula_nao_declarada,quantidade_matricula_branca,
quantidade_matricula_preta, quantidade_matricula_parda, quantidade_matricula_amarela, quantidade_matricula_indigena, rede,
etapa_ensino_fundamental, etapa_ensino_fundamental_anos_iniciais, etapa_ensino_fundamental_anos_finais
FROM `basedosdados.br_inep_censo_escolar.escola` WHERE sigla_uf = "ES" AND ano = 2023') #WHERE sigla_uf = "CE" AND ano =2022'

#filtro 
sobral <- Escola_2022 %>% dplyr::filter( etapa_ensino_fundamental==1, id_municipio==3205309,
                                         rede==3)


sobral <- sobral %>%
  mutate(
    quantidade_matricula_branca = as.numeric(quantidade_matricula_branca),
    quantidade_matricula_preta = as.numeric(quantidade_matricula_preta),
    quantidade_matricula_parda = as.numeric(quantidade_matricula_parda),
    quantidade_matricula_amarela = as.numeric(quantidade_matricula_amarela),
    quantidade_matricula_indigena = as.numeric(quantidade_matricula_indigena),
    ano = as.numeric(ano)
  )


sobral <- sobral %>% mutate(total_m = quantidade_matricula_branca+quantidade_matricula_preta+
                              quantidade_matricula_parda+quantidade_matricula_amarela+quantidade_matricula_indigena)


sobral <- sobral %>% mutate(prop.branco = (quantidade_matricula_branca/total_m),
                            prop.pardo = (quantidade_matricula_parda/total_m),
                            prop.preto = (quantidade_matricula_preta/total_m),
                            prop.amarelo = (quantidade_matricula_amarela/total_m),
                            prop.indigena = (quantidade_matricula_indigena/total_m),
                            prop.negro = ((quantidade_matricula_parda+quantidade_matricula_preta)/total_m)
) 
#library(tidyr)
colnames(sobral)
sobral  <- sobral %>% pivot_longer(cols = c(prop.branco, prop.pardo, prop.preto, 
                                            prop.amarelo, prop.indigena, prop.negro), 
                                   names_to = "cor", values_to = "prop.cor" )

sobral <- sobral %>% select(ano, id_escola, cor, prop.cor)
#View(sobral)

n_sobral <- sobral %>% dplyr::filter(cor %in% "prop.negro")

#juntar coom dados do ideb
